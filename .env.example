# ============================================================
# VisualM Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- MySQL Database ---
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=visualm
MYSQL_USER=visualm
MYSQL_PASSWORD=change_me_db_password

# --- JWT Secret ---
# Generate a strong random string (e.g.: openssl rand -base64 32)
JWT_PASSPHRASE=change_me_jwt_secret

# --- Frontend URL ---
# Your domain with protocol (used for email links)
FRONTEND_URL=http://your-domain.com/

# --- Email (SMTP) ---
# Used for account verification and password reset emails
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Bitly (optional, for short links) ---
# BITLY_KEY=
# BITLY_GROUP_GUID=
